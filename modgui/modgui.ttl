# MOD GUI description for Dirty Talk.
# These triples are merged into the plugin .ttl when packaging for MOD
# (see mod-builder/dirty-talk.mk). Paths are relative to the .lv2 bundle root.

@prefix lv2:    <http://lv2plug.in/ns/lv2core#> .
@prefix modgui: <http://moddevices.com/ns/modgui#> .

<https://mod.audio/plugins/dirty-talk>
    modgui:gui [
        a modgui:Gui ;
        modgui:resourcesDirectory <modgui> ;
        modgui:iconTemplate <modgui/dirty-talk.html> ;
        modgui:stylesheet <modgui/stylesheet.css> ;
        modgui:screenshot <modgui/screenshot.png> ;
        modgui:thumbnail <modgui/thumbnail.png> ;
        modgui:brand "Pilal" ;
        modgui:label "Dirty Talk" ;
        modgui:model "boxy" ;
        modgui:panel "1" ;
        modgui:color "black" ;
        modgui:knob "black" ;

        # Ports surfaced to the host (parameter list / hardware addressing).
        # The icon template binds each widget by lv2:symbol (mod-port-symbol).
        modgui:port [
            lv2:index 2 ; lv2:symbol "mode"        ; lv2:name "Mode" ;
        ] , [
            lv2:index 3 ; lv2:symbol "center_freq" ; lv2:name "Center Freq" ;
        ] , [
            lv2:index 4 ; lv2:symbol "bandwidth"   ; lv2:name "Bandwidth" ;
        ] , [
            lv2:index 5 ; lv2:symbol "gate"        ; lv2:name "Gate" ;
        ] , [
            lv2:index 6 ; lv2:symbol "dry_wet"     ; lv2:name "Dry/Wet" ;
        ] ;
    ] .
